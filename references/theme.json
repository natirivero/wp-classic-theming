{
    "$schema": "https://schemas.wp.org/wp/6.9/theme.json",
    "version": 3,
    "settings": {
      "blocks": {},
      "color": {
        "gradients": [
          {
            "gradient": "linear-gradient(90deg, color1 0%, color2 100%)",
            "name": "Primary Gradient",
            "slug": "primary-gradient"
          }
        ],
        "palette": [
          {
            "color": "#FFFFFF",
            "name": "Base",
            "slug": "base"
          },
          {
            "color": "#F8FBF4",
            "name": "Base / Two",
            "slug": "base-2"
          },
          {
            "color": "#E3EAF5",
            "name": "Base / Three",
            "slug": "base-3"
          },
          {
            "color": "#0D2543",
            "name": "Contrast",
            "slug": "contrast"
          },
          {
            "color": "#2196F3",
            "name": "Contrast / Two",
            "slug": "contrast-2"
          },
          {
            "color": "#E6CFA6",
            "name": "Contrast / Three",
            "slug": "contrast-3"
          },
          {
            "color": "#916F0B",
            "name": "Accent",
            "slug": "accent"
          },
          {
            "color": "#E0AF56",
            "name": "Accent / Two",
            "slug": "accent-2"
          }
        ]
      },
      "layout": {
        "contentSize": "1244px",
        "wideSize": "100%"
      },
      "typography": {
        "fontFamilies": [
          {
            "fontFamily": "-apple-system, BlinkMacSystemFont, avenir next, avenir, segoe ui, helvetica neue, helvetica, Cantarell, Ubuntu, roboto, noto, arial, sans-serif",
            "name": "System Sans-serif",
            "slug": "system-sans-serif"
          },
          {
            "fontFamily": "Iowan Old Style, Apple Garamond, Baskerville, Times New Roman, Droid Serif, Times, Source Serif Pro, serif, Apple Color Emoji, Segoe UI Emoji, Segoe UI Symbol",
            "name": "System Serif",
            "slug": "system-serif"
          },
          {
            "fontFace": [
              {
                "fontFamily": "Roboto",
                "fontStyle": "normal",
                "fontWeight": "400",
                "fontDisplay": "swap",
                "src": ["file:./assets/fonts/roboto/roboto-400-normal.woff2"]
              },
              {
                "fontFamily": "Roboto",
                "fontStyle": "normal",
                "fontWeight": "500",
                "fontDisplay": "swap",
                "src": ["file:./assets/fonts/roboto/roboto-500-normal.woff2"]
              },
              {
                "fontFamily": "Roboto",
                "fontStyle": "normal",
                "fontWeight": "700",
                "fontDisplay": "swap",
                "src": ["file:./assets/fonts/roboto/roboto-700-normal.woff2"]
              },
              {
                "fontFamily": "Roboto",
                "fontStyle": "italic",
                "fontWeight": "400",
                "fontDisplay": "swap",
                "src": ["file:./assets/fonts/roboto/roboto-400-italic.woff2"]
              }
            ],
            "fontFamily": "Roboto, sans-serif",
            "name": "Roboto",
            "slug": "roboto"
          },
          {
            "fontFace": [
              {
                "fontFamily": "\"Coming Soon\"",
                "fontStyle": "normal",
                "fontWeight": "400",
                "fontDisplay": "swap",
                "src": [
                  "file:./assets/fonts/coming-soon/coming-soon-400-normal.woff2"
                ]
              }
            ],
            "fontFamily": "\"Coming Soon\", cursive",
            "name": "Coming Soon",
            "slug": "coming-soon"
          },
          {
            "fontFace": [
              {
                "fontFamily": "Caveat",
                "fontStyle": "normal",
                "fontWeight": "400",
                "fontDisplay": "swap",
                "src": ["file:./assets/fonts/caveat/caveat-400-normal.woff2"]
              }
            ],
            "fontFamily": "Caveat, cursive",
            "name": "Caveat",
            "slug": "caveat"
          },
          {
            "fontFace": [
              {
                "fontFamily": "Montserrat",
                "fontStyle": "normal",
                "fontWeight": "400",
                "fontDisplay": "swap",
                "src": [
                  "file:./assets/fonts/montserrat/montserrat-400-normal.woff2"
                ]
              },
              {
                "fontFamily": "Montserrat",
                "fontStyle": "normal",
                "fontWeight": "500",
                "fontDisplay": "swap",
                "src": [
                  "file:./assets/fonts/montserrat/montserrat-500-normal.woff2"
                ]
              },
              {
                "fontFamily": "Montserrat",
                "fontStyle": "normal",
                "fontWeight": "600",
                "fontDisplay": "swap",
                "src": [
                  "file:./assets/fonts/montserrat/montserrat-600-normal.woff2"
                ]
              },
              {
                "fontFamily": "Montserrat",
                "fontStyle": "normal",
                "fontWeight": "700",
                "fontDisplay": "swap",
                "src": [
                  "file:./assets/fonts/montserrat/montserrat-700-normal.woff2"
                ]
              },
              {
                "fontFamily": "Montserrat",
                "fontStyle": "italic",
                "fontWeight": "500",
                "fontDisplay": "swap",
                "src": [
                  "file:./assets/fonts/montserrat/montserrat-500-italic.woff2"
                ]
              }
            ],
            "fontFamily": "Montserrat, sans-serif",
            "name": "Montserrat",
            "slug": "montserrat"
          }
        ],
        "fontSizes": [
          {
            "name": "Heading 1",
            "slug": "heading-1",
            "size": "clamp(42px, 5.6vw, 80px)",
            "fluid": {
              "min": "42px",
              "max": "80px"
            }
          },
          {
            "name": "Heading 2",
            "slug": "heading-2",
            "size": "clamp(36px, 4.5vw, 64px)",
            "fluid": {
              "min": "36px",
              "max": "64px"
            }
          },
          {
            "name": "Heading 3",
            "slug": "heading-3",
            "size": "clamp(32px, 3.4vw, 48px)",
            "fluid": {
              "min": "32px",
              "max": "48px"
            }
          },
          {
            "name": "Heading 4",
            "slug": "heading-4",
            "size": "clamp(28px, 2.3vw, 32px)",
            "fluid": {
              "min": "28px",
              "max": "32px"
            }
          },
          {
            "name": "Heading 5",
            "slug": "heading-5",
            "size": "clamp(24px, 2vw, 28px)",
            "fluid": {
              "min": "24px",
              "max": "28px"
            }
          },
          {
            "name": "Heading 6",
            "slug": "heading-6",
            "size": "clamp(20px, 1.7vw, 24px)",
            "fluid": {
              "min": "20px",
              "max": "24px"
            }
          },
          {
            "name": "Medium",
            "slug": "medium",
            "size": "18px",
            "fluid": false
          },
          {
            "name": "Small",
            "slug": "small",
            "size": "14px",
            "fluid": false
          }
        ]
      },
      "useRootPaddingAwareAlignments": true
    },
    "styles": {
      "color": {
        "background": "var(--wp--preset--color--base-3)",
        "text": "var(--wp--preset--color--contrast)"
      },
      "elements": {
        "button": {
          "color": {
            "background": "var(--wp--preset--color--accent)",
            "text": "var(--wp--preset--color--base)"
          },
          "border": {
            "color": "var(--wp--preset--color--accent)",
            "radius": "2px",
            "style": "solid",
            "width": "2px"
          },
          "shadow": "0 1px 2px 0 rgba(0, 0, 0, 0.30)",
          "spacing": {
            "padding": {
              "bottom": "16px",
              "left": "48px",
              "right": "48px",
              "top": "16px"
            }
          },
          "typography": {
            "fontFamily": "var(--wp--preset--font-family--roboto)",
            "fontSize": "24px",
            "fontStyle": "normal",
            "fontWeight": "500",
            "lineHeight": "1.4em"
          },
          ":hover": {
            "border": {
              "color": "var(--wp--preset--color--accent-2)"
            },
            "color": {
              "background": "var(--wp--preset--color--accent-2)",
              "text": "var(--wp--preset--color--contrast)"
            }
          },
          ":active": {
            "color": {
              "background": "var(--wp--preset--color--accent-2)",
              "text": "var(--wp--preset--color--contrast)"
            }
          },
          ":focus": {
            "border": {
              "color": "var(--wp--preset--color--accent-2)"
            },
            "color": {
              "background": "var(--wp--preset--color--accent-2)",
              "text": "var(--wp--preset--color--contrast)"
            },
            "outline": {
              "color": "var(--wp--preset--color--accent-2)",
              "offset": "2px"
            }
          }
        },
        "h1": {
          "typography": {
            "fontSize": "var(--wp--preset--font-size--heading-1)",
            "lineHeight": "1.1em",
            "fontWeight": "500"
          }
        },
        "h2": {
          "typography": {
            "fontSize": "var(--wp--preset--font-size--heading-2)",
            "lineHeight": "1.25em"
          }
        },
        "h3": {
          "typography": {
            "fontSize": "var(--wp--preset--font-size--heading-3)",
            "lineHeight": "1.25em"
          }
        },
        "h4": {
          "typography": {
            "fontSize": "var(--wp--preset--font-size--heading-4)",
            "lineHeight": "1.4em",
            "fontWeight": "500",
            "letterSpacing": "-0.01em"
          }
        },
        "h5": {
          "typography": {
            "fontFamily": "var(--wp--preset--font-family--roboto)",
            "fontSize": "var(--wp--preset--font-size--heading-5)",
            "lineHeight": "1.35em",
            "fontWeight": "400",
            "letterSpacing": "-0.01em"
          }
        },
        "h6": {
          "typography": {
            "fontFamily": "var(--wp--preset--font-family--roboto)",
            "fontSize": "var(--wp--preset--font-size--heading-6)",
            "lineHeight": "1.4em",
            "letterSpacing": "-0.01em"
          }
        },
        "heading": {
          "color": {
            "text": "var(--wp--preset--color--contrast)"
          },
          "typography": {
            "fontFamily": "var(--wp--preset--font-family--montserrat)",
            "fontWeight": "400",
            "lineHeight": "1.4",
            "letterSpacing": "-0.02em"
          }
        },
        "link": {
          ":hover": {
            "color": {
              "text": "var(--wp--preset--color--contrast)"
            },
            "typography": {
              "fontFamily": "var(--wp--preset--font-family--roboto)",
              "textDecoration": "underline"
            }
          },
          "color": {
            "text": "var(--wp--preset--color--contrast-2)"
          }
        }
      },
      "spacing": {
        "padding": {
          "left": "",
          "right": ""
        }
      },
      "typography": {
        "fontFamily": "var(--wp--preset--font-family--roboto)",
        "letterSpacing": "-0.01em"
      }
    }
  }
  